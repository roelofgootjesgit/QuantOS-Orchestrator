# VPS / Linux — kopieer naar .env in deze map:
#   cd /root/dev/quant/quantmetrics_os/orchestrator
#   cp config.vps.example.env .env
# Pas paden aan als je repos ergens anders staan.
#
# Altijd absolute paden: dan werkt check/build/notify overal hetzelfde,
# ongeacht vanuit welke directory je python quantmetrics.py draait.

QUANTBUILD_ROOT=/root/dev/quant/quantbuildv1
QUANTBRIDGE_ROOT=/root/dev/quant/quantbridgev1
QUANTLOG_ROOT=/root/dev/quant/quantlogv1

# NIET zetten tenzij je een andere event store gebruikt.
# Standaard: <QUANTBUILD_ROOT>/data/quantlog_events
# QUANTLOG_EVENTS_ROOT=

# Op veel VPS'en: python3. Gebruik je een venv, zet hier het volledige pad
# naar de python van die venv, of activeer de venv en gebruik python.
PYTHON=python3

QUANTBUILD_CONFIG=configs/strict_prod_v2.yaml
QUANTBRIDGE_CONFIG=configs/ctrader_icmarkets_demo.yaml
